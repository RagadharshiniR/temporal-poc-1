# Temporal Configuration
TEMPORAL_HOST=temporal
TEMPORAL_PORT=7233

# API Server Configuration
API_PORT=3000
API_HOST=0.0.0.0

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
